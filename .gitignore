# Claude Code — ignore everything under .claude/ except project-scoped agent
# charters and the team-of-agents skills (see docs/build/PLAN.md, META.md).
.claude/*
!.claude/agents/
!.claude/skills/
.claude/skills/*
!.claude/skills/run-implement/
!.claude/skills/run-plan/
!.claude/skills/run-triage/

# Assets (large binaries)
assets/
*.mp3

# Stray screenshot drops at repo root (UUID-named PNGs from chat)
/????????-????-????-????-????????????.png

# OS
.DS_Store
Thumbs.db

# Docker
docker/data/
# Anchor to repo root — `data/` (unanchored) accidentally swallowed
# scripts/data/* source code. Keep the repo-root data/ folder ignored
# (working data, scraped dumps, transcript caches) without affecting
# nested data/ directories elsewhere in the tree.
/data/

# Generated scrape output that does belong under scripts/data/ but
# shouldn't be tracked (large JSON dumps + Python bytecode).
scripts/data/scraped_*.json
scripts/data/__pycache__/

# Local runtime logs (uvicorn etc.)
.run/

# Sensitive files
docs/aws-resource-inventory.md
*.egg-info
commits/
design-artifacts/
