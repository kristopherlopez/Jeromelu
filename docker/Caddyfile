# Caddy auto-provisions Let's Encrypt certs for these hostnames via HTTP-01.
# Requires:
#   - DNS A record for each hostname pointing at this Lightsail static IP
#   - Lightsail firewall: 80, 443 open to 0.0.0.0/0
# Cert renewal: automatic, every ~60 days.

# Web app (CloudFront sits in front for jeromelu.ai/www, but Caddy still
# terminates TLS so CloudFront-to-origin is encrypted).
# HTTP block for CloudFront origin fetches. CF forwards the user's Host
# header (jeromelu.ai or www.jeromelu.ai) and connects to origin via HTTP.
# We accept all three names here so no redirect kicks in. CF terminates
# user-facing TLS via the us-east-1 ACM cert.
http://jeromelu.ai, http://www.jeromelu.ai, http://origin.jeromelu.ai {
	encode zstd gzip
	reverse_proxy web:3000
	log {
		output stdout
		format console
	}
}

# HTTPS for direct visitors (e.g. anyone who hits the bare IP or origin
# subdomain over HTTPS). Auto Let's Encrypt.
jeromelu.ai, www.jeromelu.ai, origin.jeromelu.ai {
	encode zstd gzip
	reverse_proxy web:3000
	log {
		output stdout
		format console
	}
}

# API — direct to Caddy (no CloudFront in front).
api.jeromelu.ai {
	encode zstd gzip
	reverse_proxy api:8000
	log {
		output stdout
		format console
	}
}
